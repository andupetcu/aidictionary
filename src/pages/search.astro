---
import Base from '../layouts/Base.astro';
---
<Base title="Search — A·I·Z" description="Search across 3,700+ technology, AI, design, and programming terms.">
  <section class="max-w-4xl mx-auto px-4 pt-12 pb-16">
    <h1 class="text-4xl font-black mb-8">
      <span class="bg-gradient-to-r from-pink-brand to-orange-brand bg-clip-text text-transparent">Search</span>
    </h1>
    <div class="relative mb-8">
      <input
        id="search-input"
        type="search"
        placeholder="Search terms…"
        class="w-full px-5 py-4 text-lg border-2 border-gray-200 rounded-xl focus:border-pink-brand focus:outline-none transition-colors"
        autofocus
      />
    </div>
    <div id="search-results" class="columns-1 md:columns-2 gap-8"></div>
    <div id="no-results" class="text-center py-12 hidden">
      <p class="text-gray-400 mb-4">No terms found for "<span id="no-results-query"></span>"</p>
      <button
        id="generate-btn"
        class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-pink-brand to-orange-brand text-white font-semibold rounded-xl hover:opacity-90 transition-opacity"
      >
        ⚡ Generate with AI
      </button>
      <p id="generate-status" class="mt-3 text-sm text-gray-400 hidden"></p>
    </div>
    <div id="generated-result" class="hidden mt-8">
      <div class="border-2 border-orange-brand/30 rounded-xl p-6 bg-orange-50/50">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xs font-bold text-white bg-gradient-to-r from-pink-brand to-orange-brand px-2 py-0.5 rounded-full">⚡ AI-generated &amp; saved</span>
        </div>
        <article class="break-inside-avoid">
          <dt>
            <a id="gen-term" href="#" class="bg-yellow-300 px-1.5 py-0.5 font-bold text-gray-900 hover:bg-yellow-400 transition-colors"></a>
            <span id="gen-category" class="ml-2 text-xs font-semibold text-pink-600 uppercase tracking-wider"></span>
          </dt>
          <dd id="gen-definition" class="mt-1 text-sm text-gray-600 leading-relaxed"></dd>
          <dd id="gen-see-also" class="mt-2 text-xs text-gray-400"></dd>
        </article>
      </div>
    </div>
  </section>

  <script>
    let debounceTimer: number;
    const input = document.getElementById('search-input') as HTMLInputElement;
    const results = document.getElementById('search-results')!;
    const noResults = document.getElementById('no-results')!;
    const noResultsQuery = document.getElementById('no-results-query')!;
    const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement;
    const generateStatus = document.getElementById('generate-status')!;
    const generatedResult = document.getElementById('generated-result')!;

    // URL param support
    const params = new URLSearchParams(window.location.search);
    if (params.get('q')) {
      input.value = params.get('q')!;
      doSearch(params.get('q')!);
    }

    input.addEventListener('input', (e) => {
      const q = (e.target as HTMLInputElement).value;
      clearTimeout(debounceTimer);
      generatedResult.classList.add('hidden');
      generateStatus.classList.add('hidden');
      if (!q.trim()) {
        results.innerHTML = '';
        noResults.classList.add('hidden');
        return;
      }
      debounceTimer = window.setTimeout(() => doSearch(q), 300);
    });

    async function doSearch(query: string) {
      const q = query.trim();
      if (!q) return;

      try {
        const res = await fetch('/api/search.json', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ q }),
        });
        const data = await res.json();
        const matches = data.results || [];

        if (matches.length === 0) {
          results.innerHTML = '';
          noResultsQuery.textContent = q;
          noResults.classList.remove('hidden');
          return;
        }

        noResults.classList.add('hidden');
        results.innerHTML = matches.map((t: any) => {
          const slug = t.slug || t.term.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
          const sourceBadge = t.source === 'llm' ? '<span class="ml-2 text-[10px] font-bold text-orange-500">⚡ AI</span>'
            : t.source === 'user' ? '<span class="ml-2 text-[10px] font-bold text-blue-500">👤</span>' : '';
          return `
          <article class="break-inside-avoid mb-6">
            <dt>
              <a href="/definition/${slug}" class="bg-yellow-300 px-1.5 py-0.5 font-bold text-gray-900 hover:bg-yellow-400 transition-colors">${t.term}</a>
              <span class="ml-2 text-xs font-semibold text-pink-600 uppercase tracking-wider">${t.category}</span>
              ${sourceBadge}
            </dt>
            <dd class="mt-1 text-sm text-gray-600 leading-relaxed">${t.definition}</dd>
          </article>`;
        }).join('');
      } catch (err) {
        // Fallback: show error
        results.innerHTML = '<p class="text-red-400 text-sm">Search error. Please try again.</p>';
      }
    }

    generateBtn.addEventListener('click', async () => {
      const q = input.value.trim();
      if (!q) return;

      generateBtn.disabled = true;
      generateBtn.textContent = 'Generating…';
      generateStatus.textContent = 'Asking AI to define this term…';
      generateStatus.classList.remove('hidden');
      generatedResult.classList.add('hidden');

      try {
        const res = await fetch('/api/generate.json', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ term: q }),
        });
        const data = await res.json();

        if (data.error) {
          generateStatus.textContent = 'Error: ' + data.error;
          return;
        }

        const t = data.term;
        const slug = t.slug || t.term.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
        const termEl = document.getElementById('gen-term') as HTMLAnchorElement;
        termEl.textContent = t.term;
        termEl.href = `/definition/${slug}`;
        document.getElementById('gen-category')!.textContent = t.category;
        document.getElementById('gen-definition')!.textContent = t.definition;
        const seeAlsoEl = document.getElementById('gen-see-also')!;
        if (t.seeAlso && t.seeAlso.length > 0) {
          seeAlsoEl.innerHTML = 'See also: ' + t.seeAlso.map((sa: string) => {
            const saSlug = sa.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
            return `<a href="/definition/${saSlug}" class="text-pink-600 hover:underline">${sa}</a>`;
          }).join(', ');
        } else {
          seeAlsoEl.textContent = '';
        }

        generateStatus.classList.add('hidden');
        generatedResult.classList.remove('hidden');
        noResults.classList.add('hidden');
      } catch (err) {
        generateStatus.textContent = 'Failed to generate. Please try again.';
      } finally {
        generateBtn.disabled = false;
        generateBtn.textContent = '⚡ Generate with AI';
      }
    });
  </script>
</Base>
