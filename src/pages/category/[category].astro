---
import Base from '../../layouts/Base.astro';
import terms from '../../content/en/terms.json';

export function getStaticPaths() {
  const slugify = (cat: string) => cat.toLowerCase().replace(/[^a-z0-9]+/g, '-');
  const categoryMap: Record<string, { term: string; category: string; definition: string; seeAlso?: string[]; letter: string }[]> = {};
  for (const [letter, items] of Object.entries(terms)) {
    for (const t of items as any[]) {
      const slug = slugify(t.category);
      if (!categoryMap[slug]) categoryMap[slug] = [];
      categoryMap[slug].push({ ...t, letter });
    }
  }
  return Object.entries(categoryMap).map(([slug, items]) => ({
    params: { category: slug },
    props: { category: items[0].category, items: items.sort((a, b) => a.term.localeCompare(b.term)) },
  }));
}

const { category, items } = Astro.props;

const slugify = (cat: string) => cat.toLowerCase().replace(/[^a-z0-9]+/g, '-');

const allCategories = [...new Set(
  Object.values(terms).flatMap((arr: any) => arr.map((t: any) => t.category))
)].sort() as string[];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `${category} terms`,
  "numberOfItems": items.length,
  "itemListElement": items.map((t, i) => ({
    "@type": "DefinedTerm",
    "position": i + 1,
    "name": t.term,
    "description": t.definition,
  })),
};
---

<Base
  title={`${category} — AI Dictionary`}
  description={`All ${category} terms in AI Dictionary. ${items.length} definitions covering ${category.toLowerCase()}.`}
  jsonLd={jsonLd}
>
  <section class="max-w-6xl mx-auto px-4 pt-12 pb-16">
    <div class="mb-10">
      <h1 class="text-5xl md:text-7xl font-black bg-gradient-to-r from-pink-brand via-red-brand to-orange-brand bg-clip-text text-transparent mb-2">
        {category}
      </h1>
      <p class="text-gray-500">{items.length} terms</p>
    </div>

    <!-- Category nav -->
    <nav class="flex flex-wrap gap-2 mb-10">
      {allCategories.map((cat) => (
        <a
          href={`/category/${slugify(cat)}`}
          class:list={[
            "px-3 py-1 rounded-full text-xs font-semibold transition-colors",
            cat === category
              ? "bg-gradient-to-r from-pink-brand to-orange-brand text-white"
              : "bg-gray-100 text-gray-600 hover:bg-gray-200"
          ]}
        >
          {cat}
        </a>
      ))}
    </nav>

    <dl class="columns-1 md:columns-2 lg:columns-3 gap-x-10">
      {items.map((t) => (
        <article class="break-inside-avoid mb-8">
          <dt>
            <span class="bg-yellow-highlight px-2 py-0.5 font-bold text-lg text-body inline-block">{t.term}</span>
            <span class="ml-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">{t.letter}</span>
          </dt>
          <dd class="mt-2 text-sm text-gray-600 leading-relaxed">
            {t.definition}
            {t.seeAlso && t.seeAlso.length > 0 && (
              <p class="mt-2 text-xs text-gray-400">
                <span class="font-medium">See also:</span> {t.seeAlso.map((sa, i) => (
                  <>{i > 0 && ', '}<a href={`/${sa[0].toLowerCase()}#${sa.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`} class="text-pink-brand hover:underline">{sa}</a></>
                ))}
              </p>
            )}
          </dd>
        </article>
      ))}
    </dl>
  </section>
</Base>
